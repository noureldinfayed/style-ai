# ─── AI ──────────────────────────────────────────────────────────────────────
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# ─── EMAIL ────────────────────────────────────────────────────────────────────
# Get from: https://resend.com/api-keys
RESEND_API_KEY=re_...
# Email address that receives contact form submissions
CONTACT_EMAIL_TO=hello@yourdomain.com

# ─── SITE ─────────────────────────────────────────────────────────────────────
# Production URL (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://yourdomain.com
NEXT_PUBLIC_BUSINESS_NAME=Business Name
NEXT_PUBLIC_BUSINESS_PHONE=+20 100 000 0000
NEXT_PUBLIC_BUSINESS_EMAIL=hello@yourdomain.com

# ─── ADMIN ───────────────────────────────────────────────────────────────────
# Simple PIN for any protected admin pages — use a strong random value
ADMIN_PIN=000000
